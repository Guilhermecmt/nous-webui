# ============================================================
#  Nous WebUI - .gitignore
#  IMPORTANTE: mantem segredos e dados pessoais FORA do repositorio.
# ============================================================

# --- Dados privados / backups (contem conversas, conta, senha) ---
bkp/*
!bkp/.gitkeep
*.zip
*.db
*.db-shm
*.db-wal
*.sqlite
NousData/

# --- Cache de busca (gerado pelo search/) ---
search/search_cache.sqlite

# --- Artefatos de build ---
*.exe
launchers/Nous.exe
launchers/Parar Nous.exe
branding/assets/nous.ico
dist/

# --- Texturas de marmore (geradas; nao usadas no tema padrao) ---
branding/assets/marble*.png

# --- Logs ---
*.log
serve-log.txt
install-log.txt

# --- Python ---
__pycache__/
*.py[cod]
*.egg-info/
.venv/
venv/
env/

# --- Ambiente Open WebUI (nunca versionar o venv) ---
open-webui/
Lib/
Scripts/
Include/
share/
pyvenv.cfg

# --- Segredos / config local ---
*.local
.env
config.local.*
# Chave secreta do Open WebUI (sessoes) - NUNCA versionar
.webui_secret_key
**/.webui_secret_key

# --- Sistema operacional ---
Thumbs.db
desktop.ini
.DS_Store
